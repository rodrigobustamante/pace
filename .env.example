# ─── STRAVA ───────────────────────────────────────────────
# Get from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random string used to validate incoming webhook calls. Generate with: openssl rand -hex 16
STRAVA_WEBHOOK_VERIFY_TOKEN=

# ─── GOOGLE GEMINI ────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Model in use: gemini-2.5-flash
GEMINI_API_KEY=

# ─── DATABASE ─────────────────────────────────────────────
# Local (Docker):     postgresql://pace:pace_local_pw@localhost:5432/pace_dev
# Production:         Supabase connection string
DATABASE_URL=postgresql://pace:pace_local_pw@localhost:5432/pace_dev

# ─── REDIS ────────────────────────────────────────────────
# Local (Docker):     redis://localhost:6379
# Production:         Upstash connection string
REDIS_URL=redis://localhost:6379

# ─── APP ──────────────────────────────────────────────────
# Local:        http://localhost:3000
# Production:   your deployed domain
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── SECURITY ─────────────────────────────────────────────
# AES-256 key for encrypting Strava tokens at rest in the DB
# Generate with: openssl rand -hex 32
# ⚠️  NEVER commit the real value — this file is a template only
ENCRYPTION_KEY=
