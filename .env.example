# ─── STRAVA ───────────────────────────────────────────────
# Get from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random string used to validate incoming webhook calls. Generate with: openssl rand -hex 16
STRAVA_WEBHOOK_VERIFY_TOKEN=

# ─── GOOGLE GEMINI ────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Model in use: gemini-2.5-flash
GEMINI_API_KEY=

# ─── DATABASE ─────────────────────────────────────────────
# Local (Docker): same value for both (no pooler).
# Supabase on Vercel: DATABASE_URL = Transaction pooler (port 6543, add ?pgbouncer=true if shown in dashboard)
DATABASE_URL=postgresql://pace:pace_local_pw@localhost:5432/pace_dev
# DIRECT_URL   = direct session mode (port 5432) — used by prisma migrate
DIRECT_URL=postgresql://pace:pace_local_pw@localhost:5432/pace_dev

# ─── REDIS ────────────────────────────────────────────────
# Local (Docker):  redis://localhost:6379
# Upstash:         Redis tab → copy "Redis URL" (starts with rediss:// — TLS)
REDIS_URL=redis://localhost:6379

# ─── APP ──────────────────────────────────────────────────
# Full origin (scheme required for Strava OAuth). Examples:
#   http://localhost:3000
#   https://your-app.vercel.app
# Host-only (e.g. xxx.vercel.app) is normalized to https:// in code, but prefer the full URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── SECURITY ─────────────────────────────────────────────
# AES-256 key for encrypting Strava tokens at rest in the DB
# Generate with: openssl rand -hex 32
# ⚠️  NEVER commit the real value — this file is a template only
ENCRYPTION_KEY=
